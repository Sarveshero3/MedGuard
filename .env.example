# ============================================================
# MedGuard — Root Environment Variables
# Copy to .env and fill in real values
# ============================================================

# PostgreSQL
POSTGRES_USER=medguard
POSTGRES_PASSWORD=medguard_dev
POSTGRES_DB=medguard
DATABASE_URL=postgresql://medguard:medguard_dev@postgres:5432/medguard

# JWT — ACCESS_TTL determines access token lifetime; REFRESH_TTL determines refresh token lifetime.
# Note: Keep both in sync with rotation schedules.
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Database Connection Pool Scaling
DB_POOL_MAX=20

# Environment — controls mock email gating (development = tokens logged to console)
NODE_ENV=development

# ms1 — Core API
MS1_PORT=4000
MS2_BASE_URL=http://ms2-agent-service:8000

# ms2 — Agent Service
MS2_PORT=8000
NVIDIA_API_KEY=key-here
LOG_LEVEL=info

# AWS SES (production configuration)
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_ADDRESS=noreply@medguard.example.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend
VITE_API_BASE_URL=/api
